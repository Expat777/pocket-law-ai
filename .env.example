# Telegram
BOT_TOKEN=                        # токен бота от @BotFather
# Если хостинг режет api.telegram.org (см. STATUS.md, Роль 1 — блокировка на
# уровне сети РФ-хостера): HTTP- или SOCKS5-прокси до Telegram. socks5://
# требует пакета aiohttp-socks (не входит в зависимости по умолчанию).
TELEGRAM_PROXY=

# LLM API (только генерация ответов) — OpenAI-совместимый шлюз Polza.ai
LLM_API_KEY=
LLM_BASE_URL=https://api.polza.ai/api/v1
LLM_MODEL=deepseek/deepseek-v3.2
LLM_MAX_TOKENS=900

# Локальные эмбеддинги (sentence-transformers)
EMBED_MODEL=intfloat/multilingual-e5-base
EMBED_DIM=768

# Postgres
POSTGRES_USER=pocketlaw
POSTGRES_PASSWORD=pocketlaw
POSTGRES_DB=pocketlaw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Qdrant
QDRANT_URL=http://localhost:6333
# До точки И2 боевых данных в law_articles ещё нет — используйте песочницу Роли 3:
QDRANT_LAW_COLLECTION=law_articles_dev

# Опционально: если LLM API недоступен напрямую из РФ
HTTPS_PROXY=
