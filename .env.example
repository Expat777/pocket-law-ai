# Telegram
BOT_TOKEN=                        # токен бота от @BotFather
# Если хостинг режет api.telegram.org (см. STATUS.md, Роль 1 — блокировка на
# уровне сети РФ-хостера): HTTP- или SOCKS5-прокси до Telegram. aiogram
# требует пакет aiohttp-socks для ЛЮБОГО прокси (уже в зависимостях).
TELEGRAM_PROXY=

# LLM API — OpenAI-совместимый шлюз Polza.ai. Один ключ/база обслуживают ВСЕ
# обращения к модели: intent (роутинг), compose (генерация ответа), HyDE (ретрив)
# и STT (распознавание голоса) — отдельного провайдера под голос нет (см. ниже).
LLM_API_KEY=
LLM_BASE_URL=https://api.polza.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_MAX_TOKENS=900
LLM_TEMPERATURE=0.2               # температура compose (генерация ответа); intent/HyDE — свои 0.0 ниже

# Локальные эмбеддинги (sentence-transformers). Модель выбрана бенчмарком
# Роли 3 2026-07-07 (pipeline/benchmark_embeddings.ipynb, R@5=0.97 на 62 вопросах).
EMBED_MODEL=deepvk/USER-bge-m3
EMBED_DIM=1024

# Postgres
POSTGRES_USER=pocketlaw
POSTGRES_PASSWORD=pocketlaw
POSTGRES_DB=pocketlaw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Хранилище бота: "memory" (по умолчанию, не переживает рестарт) или "postgres"
# (PostgresRepository, Роль 1 — согласие/история/rate-limit переживают рестарт).
STORAGE_BACKEND=memory

# Qdrant
QDRANT_URL=http://localhost:6333
# До точки И2 боевых данных в law_articles ещё нет — используйте песочницу Роли 3:
QDRANT_LAW_COLLECTION=law_articles_dev

# Опционально: если LLM API недоступен напрямую из РФ
HTTPS_PROXY=

# --- Настройки агента (Роль 2) — ВСЕ опциональны, дефолты в agent/config.py ---
# Ниже — только ручки, влияющие на поведение; здесь для видимости нового
# разработчика. Полный список с обоснованиями — в agent/config.py (16 getenv
# в одном месте). Прод переопределяет их своим .env, а не этим файлом.
AGENT_HYDE=1                      # 0 = выключить HyDE-фьюжн (первый рычаг при лимитах Polza: -1 вызов LLM/вопрос)
AGENT_INTENT_TEMPERATURE=0.0      # температура узла intent (детерминизм роутинга)
AGENT_HYDE_TEMPERATURE=0.0        # температура генерации HyDE (детерминизм ретрива)
AGENT_ANCHOR_ARTICLES=1           # 0 = выключить якоря фундамент-статей (залив/собака→ГК 1064, ДТП→ГК 1079)
AGENT_CITATION_TEXT_CHARS=450     # длина дословной выдержки статьи под «Основание»
AGENT_DOC_CONTEXT_CHARS=3000      # сколько текста присланного документа видят intent/compose

# --- Распознавание речи (STT) — тот же ключ/база, что и LLM выше ---
STT_MODEL=openai/whisper-large-v3
STT_LANGUAGE=ru                   # язык распознавания (наши пользователи — русский)
STT_MAX_BYTES=26214400            # лимит размера аудио, 25 МБ (лимит OpenAI-формата)
STT_TIMEOUT=90

# --- Офлайн-оценка качества (agent/eval/judge.py, к защите) ---
JUDGE_MODEL=                      # модель LLM-судьи; пусто = тот же LLM_MODEL
